# new-pawnshop-admin environment variables
# Local dev reads .env.local. On Vercel, set these in Project Settings > Environment Variables.

NODE_ENV=production

# Canonical URL of the admin deployment. Must match the Google OAuth redirect URI.
NEXTAUTH_URL=https://your-admin.vercel.app

# NextAuth secret (the code reads SECRET, not NEXTAUTH_SECRET). Long random string.
SECRET=replace-with-a-long-random-secret

# Google OAuth credentials. Add https://your-admin.vercel.app/api/auth/callback/google
# as an Authorized redirect URI in Google Cloud Console.
GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# Comma-separated allowlist of admin emails. Required in production.
ADMIN_EMAILS=you@example.com

# MongoDB Atlas (same cluster as the backend). Percent-encode special chars in the password.
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/?appName=Cluster0

# Backend API base (no trailing /api). MUST be reachable from the admin server.
AUCTION_BACKEND_URL=https://your-backend.onrender.com

# Shared service token. MUST match AUCTION_ADMIN_TOKEN in the backend.
AUCTION_ADMIN_TOKEN=replace-with-a-strong-shared-token

# Local-only credentials login password (dev-login provider, non-production only).
DEV_ADMIN_PASSWORD=admin

# --- Image upload storage (S3/R2). OPTIONAL ---
# Leave these empty to store product images inline as base64 in MongoDB (current default).
# Fill them in later to offload images to S3-compatible storage (e.g. Cloudflare R2).
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
